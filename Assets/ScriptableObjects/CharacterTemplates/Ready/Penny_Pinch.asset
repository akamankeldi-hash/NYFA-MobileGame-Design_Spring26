  m_Name: Penny_Pinch
  m_EditorClassIdentifier: Assembly-CSharp::CharacterTemplateSO
  characterFirstName: Penny
  characterLastName: Pinch
  characterAge: 11
  traitJob: Lemonade Stand Entrepreneur
  traitCauseOfDeath: Crushed by a giant wooden sign she built to advertise her lemonade
    across the street from a rival kid's stand
  traitPersonality: Ruthless, hyper-capitalist, entirely profit-driven, sees everything
    as a transaction
  characterSin: 5
  correctVerdictIsHeaven: 1
  upperBody: 1
  lowerBody: 0
  face: 0
  upperBodyMaterial: {fileID: 2100000, guid: 5263163200658e340a8adf700274873f, type: 2}
