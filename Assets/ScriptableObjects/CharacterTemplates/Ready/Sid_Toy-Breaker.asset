  characterFirstName: Sid
  characterLastName: Toy-Breaker
  characterAge: 9
  traitJob: Playground Menace
  traitCauseOfDeath: Licked a freezing cold metal swing set pole on a dare and couldn't
    get unstuck before a blizzard hit
  traitPersonality: Mean, loud, takes other kids' lunch money, easily angered
  characterSin: 3
  correctVerdictIsHeaven: 1
