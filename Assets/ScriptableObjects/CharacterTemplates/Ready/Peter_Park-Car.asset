  characterFirstName: Peter
  characterLastName: Park-Car
  characterAge: 67
  traitJob: Birthday Party Entertainer
  traitCauseOfDeath: Slipped while trying to catch a toddler falling out of a bouncy
    castle, taking the impact himself
  traitPersonality: Awkward, incredibly selfless, apologetic, and pure-hearted
  characterSin: 0
  correctVerdictIsHeaven: 1
  upperBody: 1
