  characterFirstName: Donald
  characterLastName: McRonald
  characterAge: 63
  traitJob: Bootleg Fast Food CEO
  traitCauseOfDeath: Slipped on a puddle of counterfeit secret sauce while escaping
    a health inspector.
  traitPersonality: Cheap, frantic, paranoid, and obsessed with cutting corners
  characterSin: 5
  correctVerdictIsHeaven: 0
  upperBody: 0
  lowerBody: 0
  upperBodyMaterial: {fileID: 2100000, guid: 4ab22ddb73955864db305340f91e00bb, type: 2}
